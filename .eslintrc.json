{
  "env": {
    "browser": true,
    "greasemonkey": true,
    "es2021": true
  },
  "extends": "eslint:recommended",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "script"
  },
  "globals": {
    "GM_xmlhttpRequest": "readonly",
    "GM_getValue": "readonly",
    "GM_setValue": "readonly",
    "GM_addStyle": "readonly"
  },
  "rules": {
    "no-unused-vars": ["warn", { "args": "none" }],
    "no-constant-condition": "warn",
    "no-empty": "warn"
  }
}
